// --- CLEAN PHYSICS ---
max_speed_fwd = 3.5;    // Top speed forward
max_speed_rev = 2.0;    // Top speed backward (a bit slower for control)
accel = 0.2;            // How fast we reach top speed
decel = 0.1;            // How fast we naturally drift to a stop

// --- STARTING POSITION ---
start_x = 100; // Make sure these are in open water!
start_y = 100;

x = start_x;
y = start_y;

image_angle = 0;
rotate_speed = 3.5;